# Скопируйте в .env.local и заполните (файл в .gitignore).
# Firebase Console → Project settings → Your apps → Web app → SDK setup (config).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# После первого деплоя правил подставьте тот же ID, что и VITE_FIREBASE_PROJECT_ID:
# в файле .firebaserc замените YOUR_FIREBASE_PROJECT_ID на реальный id.
