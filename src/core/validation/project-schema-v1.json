        "wallId": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "above",
            "lintel_top",
            "lintel_bottom",
            "side_left",
            "side_right",
            "side_fix_left",
            "side_fix_right",
            "below"
          ]
        },
        "profileId": { "type": "string", "minLength": 1 },
        "lengthMm": { "type": "number", "exclusiveMinimum": 0 },
        "markLabel": { "type": "string" },
        "sequenceIndex": { "type": "number" }
      }
