        "editor2d": {
          "type": "object",
          "additionalProperties": false,
          "required": ["linearPlacementMode", "wallShapeMode", "slabBuildMode"],
          "properties": {
            "linearPlacementMode": {
              "type": "string",
              "enum": ["center", "leftEdge", "rightEdge"]
            },
            "wallShapeMode": {
              "type": "string",
              "enum": ["line", "rectangle"]
            },
            "slabBuildMode": {
              "type": "string",
              "enum": ["rectangle", "polyline"]
            },
            "snapToVertex": { "type": "boolean" },
            "snapToEdge": { "type": "boolean" },
            "snapToGrid": { "type": "boolean" },
            "debugLumberPieceLabels2d": { "type": "boolean" }
          }
        }
      }
    },
    "viewState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activeTab", "viewport2d", "viewport3d"],
