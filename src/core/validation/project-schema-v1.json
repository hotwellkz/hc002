        "pitchDeg",
        "baseLevelMm",
        "eaveOverhangMm",
        "sideOverhangMm",
        "ridgeUnitPlan",
        "drainUnitPlan",
        "ridgeAlong",
        "generatedPlaneIds",
        "ridgeSegmentsPlanMm",
