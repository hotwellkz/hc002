        "wallIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "layerId": { "type": "string" },
        "textValueMm": { "type": "number" },
        "extensionOvershootMm": { "type": "number" }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gridStepMm", "editor2d"],
      "properties": {
        "gridStepMm": { "type": "number", "exclusiveMinimum": 0 },
        "show2dGrid": { "type": "boolean" },
