        "baseLevelMm": { "type": "number" },
        "eaveOverhangMm": { "type": "number", "minimum": 0 },
        "sideOverhangMm": { "type": "number", "minimum": 0 },
        "ridgeUnitPlan": { "$ref": "#/$defs/point2d" },
        "drainUnitPlan": { "$ref": "#/$defs/point2d" },
