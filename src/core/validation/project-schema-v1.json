              "ax": { "type": "number" },
              "ay": { "type": "number" },
              "bx": { "type": "number" },
              "by": { "type": "number" }
            }
          }
        },
        "createdAt": { "type": "string", "minLength": 1 },
        "updatedAt": { "type": "string", "minLength": 1 }
      }
    },
