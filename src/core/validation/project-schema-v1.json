{
  "$id": "https://sip-house-designer.local/schema/project-v1.json",
  "title": "SIP House Project v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "createdAt",
    "updatedAt",
    "units",
    "layers",
    "activeLayerId",
    "visibleLayerIds",
    "walls",
    "wallCalculations",
    "wallJoints",
    "openings",
    "openingFramingPieces",
    "rooms",
    "foundation",
    "roof",
    "materialSet",
    "sheets",
    "dimensions",
    "settings",
    "viewState",
    "profiles"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "enum": [1, 2] },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 },
    "units": { "type": "string", "const": "mm" },
    "activeLayerId": { "type": "string", "minLength": 1 },
    "projectOrigin": {
      "anyOf": [{ "$ref": "#/$defs/point2d" }, { "type": "null" }]
    },
    "visibleLayerIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/layer" }
    },
    "walls": {
      "type": "array",
      "items": { "$ref": "#/$defs/wall" }
    },
    "planLines": {
      "type": "array",
      "items": { "$ref": "#/$defs/planLine" }
    },
    "foundationStrips": {
      "type": "array",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/foundationStripSegment" },
          { "$ref": "#/$defs/foundationStripOrthoRing" },
          { "$ref": "#/$defs/foundationStripFootprintPoly" }
        ]
      }
    },
    "foundationPiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/foundationPile" }
    },
    "slabs": {
      "type": "array",
      "items": { "$ref": "#/$defs/slabEntity" }
    },
    "floorBeams": {
      "type": "array",
      "items": { "$ref": "#/$defs/floorBeamEntity" }
    },
    "roofPlanes": {
      "type": "array",
      "items": { "$ref": "#/$defs/roofPlaneEntity" }
    },
    "roofSystems": {
      "type": "array",
      "items": { "$ref": "#/$defs/roofSystemEntity" }
    },
    "roofAssemblyCalculations": {
      "type": "array",
      "items": { "$ref": "#/$defs/roofAssemblyCalculation" }
    },
    "wallCalculations": {
      "type": "array",
      "items": { "$ref": "#/$defs/wallCalculationResult" }
    },
    "wallJoints": {
      "type": "array",
      "items": { "$ref": "#/$defs/wallJoint" }
    },
    "openings": {
      "type": "array",
      "items": { "$ref": "#/$defs/opening" }
    },
    "openingFramingPieces": {
      "type": "array",
      "items": { "$ref": "#/$defs/openingFramingPiece" }
    },
    "rooms": {
      "type": "array",
      "items": { "$ref": "#/$defs/room" }
    },
    "foundation": { "$ref": "#/$defs/foundation" },
    "roof": { "$ref": "#/$defs/roof" },
    "materialSet": { "$ref": "#/$defs/materialSet" },
    "sheets": {
      "type": "array",
      "items": { "$ref": "#/$defs/sheet" }
    },
    "dimensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/dimension" }
    },
    "settings": { "$ref": "#/$defs/settings" },
    "viewState": { "$ref": "#/$defs/viewState" },
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/profile" }
    },
    "surfaceTextureState": { "$ref": "#/$defs/surfaceTextureState" }
  },
  "$defs": {
    "point2d": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "wallJoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "wallAId", "wallAEnd", "wallBId"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["CORNER_BUTT", "CORNER_MITER", "T_ABUTMENT"]
        },
        "wallAId": { "type": "string" },
        "wallAEnd": { "type": "string", "enum": ["start", "end"] },
        "wallBId": { "type": "string" },
        "wallBEnd": { "type": "string", "enum": ["start", "end"] },
        "teePointOnMainMm": { "$ref": "#/$defs/point2d" }
      }
    },
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "domain", "orderIndex", "elevationMm", "isVisible", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "domain": {
          "type": "string",
          "enum": ["floorPlan", "slab", "foundation", "roof"]
        },
        "orderIndex": { "type": "number" },
        "elevationMm": { "type": "number" },
        "levelMode": { "type": "string", "enum": ["absolute", "relativeToBelow"] },
        "offsetFromBelowMm": { "type": "number" },
        "manualHeightMm": { "type": "number" },
        "isVisible": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "surfaceTextureBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["textureId", "scalePercent"],
      "properties": {
        "textureId": { "type": "string", "minLength": 1 },
        "scalePercent": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "surfaceTextureState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project", "byLayerId", "byMeshKey"],
      "properties": {
        "project": {
          "anyOf": [{ "$ref": "#/$defs/surfaceTextureBinding" }, { "type": "null" }]
        },
        "byLayerId": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/surfaceTextureBinding" }
        },
        "byMeshKey": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/surfaceTextureBinding" }
        }
      }
    },
    "planLine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "layerId", "start", "end"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "layerId": { "type": "string", "minLength": 1 },
        "start": { "$ref": "#/$defs/point2d" },
        "end": { "$ref": "#/$defs/point2d" }
      }
    },
    "foundationStripAutoPileSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pileKind",
        "maxStepMm",
        "depthBelowStripMm",
        "placeAtCorners",
        "placeAtJoints",
        "centerIntermediate",
        "replaceExistingAuto"
      ],
      "properties": {
        "pileKind": { "type": "string", "enum": ["reinforcedConcrete", "screw"] },
        "maxStepMm": { "type": "number", "exclusiveMinimum": 0 },
        "depthBelowStripMm": { "type": "number", "exclusiveMinimum": 0 },
        "placeAtCorners": { "type": "boolean" },
        "placeAtJoints": { "type": "boolean" },
        "centerIntermediate": { "type": "boolean" },
        "replaceExistingAuto": { "type": "boolean" }
      }
    },
    "foundationStripAutoPilePersist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["settings", "batchId"],
      "properties": {
        "batchId": { "type": "string", "minLength": 1 },
        "settings": { "$ref": "#/$defs/foundationStripAutoPileSettings" }
      }
    },
    "foundationStripSegment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "layerId",
        "axisStart",
        "axisEnd",
        "outwardNormalX",
        "outwardNormalY",
        "depthMm",
        "sideOutMm",
        "sideInMm",
        "createdAt"
      ],
      "properties": {
        "kind": { "type": "string", "const": "segment" },
        "id": { "type": "string", "minLength": 1 },
        "layerId": { "type": "string", "minLength": 1 },
        "axisStart": { "$ref": "#/$defs/point2d" },
        "axisEnd": { "$ref": "#/$defs/point2d" },
        "outwardNormalX": { "type": "number" },
        "outwardNormalY": { "type": "number" },
        "depthMm": { "type": "number" },
        "sideOutMm": { "type": "number" },
        "sideInMm": { "type": "number" },
        "createdAt": { "type": "string", "minLength": 1 },
        "placementGroupId": { "type": "string" },
        "autoPile": { "$ref": "#/$defs/foundationStripAutoPilePersist" }
      }
    },
    "foundationStripFootprintPoly": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "layerId",
        "depthMm",
        "sideOutMm",
        "sideInMm",
        "createdAt",
        "outerRingMm",
        "holeRingsMm"
      ],
      "properties": {
        "kind": { "type": "string", "const": "footprint_poly" },
        "id": { "type": "string", "minLength": 1 },
        "layerId": { "type": "string", "minLength": 1 },
        "depthMm": { "type": "number" },
        "sideOutMm": { "type": "number" },
        "sideInMm": { "type": "number" },
        "createdAt": { "type": "string", "minLength": 1 },
        "outerRingMm": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/point2d" }
        },
        "holeRingsMm": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 3,
            "items": { "$ref": "#/$defs/point2d" }
          }
        },
        "autoPile": { "$ref": "#/$defs/foundationStripAutoPilePersist" }
      }
    },
    "foundationStripOrthoRing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id",
        "layerId",
        "axisXminMm",
        "axisXmaxMm",
        "axisYminMm",
        "axisYmaxMm",
        "depthMm",
        "sideOutMm",
        "sideInMm",
        "createdAt"
      ],
      "properties": {
        "kind": { "type": "string", "const": "ortho_ring" },
        "id": { "type": "string", "minLength": 1 },
        "layerId": { "type": "string", "minLength": 1 },
        "axisXminMm": { "type": "number" },
        "axisXmaxMm": { "type": "number" },
        "axisYminMm": { "type": "number" },
        "axisYmaxMm": { "type": "number" },
        "depthMm": { "type": "number" },
        "sideOutMm": { "type": "number" },
        "sideInMm": { "type": "number" },
        "createdAt": { "type": "string", "minLength": 1 },
        "autoPile": { "$ref": "#/$defs/foundationStripAutoPilePersist" }
      }
    },
    "foundationPile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "layerId",
        "pileKind",
        "centerX",
        "centerY",
        "sizeMm",
        "capSizeMm",
        "heightMm",
        "levelMm",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "layerId": { "type": "string", "minLength": 1 },
        "pileKind": { "type": "string", "enum": ["reinforcedConcrete", "screw"] },
        "centerX": { "type": "number" },
        "centerY": { "type": "number" },
        "sizeMm": { "type": "number" },
        "capSizeMm": { "type": "number" },
        "heightMm": { "type": "number" },
        "levelMm": { "type": "number" },
        "createdAt": { "type": "string", "minLength": 1 },
        "updatedAt": { "type": "string", "minLength": 1 },
        "autoPileBatchId": { "type": "string", "minLength": 1 }
      }
    },
    "wall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "layerId", "start", "end", "thicknessMm", "heightMm"],
      "properties": {
        "id": { "type": "string" },
        "layerId": { "type": "string" },
        "profileId": { "type": "string" },
        "start": { "$ref": "#/$defs/point2d" },
        "end": { "$ref": "#/$defs/point2d" },
        "thicknessMm": { "type": "number", "minimum": 0 },
        "heightMm": { "type": "number", "minimum": 0 },
        "baseElevationMm": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "placementGroupId": { "type": "string" },
        "markPrefix": { "type": "string" },
        "markSequenceNumber": { "type": "number" },
        "markLabel": { "type": "string" }
      }
    },
    "profileMaterialType": {
      "type": "string",
      "enum": ["osb", "eps", "xps", "wood", "steel", "gypsum", "concrete", "membrane", "insulation", "custom"]
    },
    "profileCategory": {
      "type": "string",
      "enum": ["wall", "slab", "roof", "beam", "pipe", "board", "custom"]
    },
    "profileCompositionMode": {
      "type": "string",
      "enum": ["layered", "solid"]
    },
    "profileLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "orderIndex", "materialName", "materialType", "thicknessMm"],
      "properties": {
        "id": { "type": "string" },
        "orderIndex": { "type": "number" },
        "materialName": { "type": "string" },
        "materialType": { "$ref": "#/$defs/profileMaterialType" },
        "thicknessMm": { "type": "number", "exclusiveMinimum": 0 },
        "widthMm": { "type": "number" },
        "heightMm": { "type": "number" },
        "note": { "type": "string" }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "category",
        "compositionMode",
        "layers",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "$ref": "#/$defs/profileCategory" },
        "compositionMode": { "$ref": "#/$defs/profileCompositionMode" },
        "defaultHeightMm": { "type": "number" },
        "defaultWidthMm": { "type": "number" },
        "defaultThicknessMm": { "type": "number" },
        "linearStockMaxLengthMm": { "type": "number", "exclusiveMinimum": 0 },
        "notes": { "type": "string" },
        "markPrefix": { "type": "string" },
        "wallManufacturing": { "$ref": "#/$defs/wallManufacturingSettings" },
        "layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/profileLayer" }
        },
        "roofAssembly": { "$ref": "#/$defs/roofProfileAssembly" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "roofProfileAssembly": {
      "type": "object",
      "description": "Узел кровли; допускаются устаревшие ключи для мягкой миграции.",
      "additionalProperties": true,
      "properties": {
        "coveringKind": {
          "type": "string",
          "enum": ["metal_tile", "profiled_sheet", "soft", "standing_seam", "other"]
        },
        "coveringMaterial": { "type": "string" },
        "coveringThicknessMm": { "type": "number" },
        "coveringAppearance3d": { "type": "string", "enum": ["color", "texture"] },
        "coveringColorHex": { "type": "string" },
        "coveringTextureId": { "type": ["string", "null"] },
        "membraneUse": { "type": "boolean" },
        "membraneThicknessMm": { "type": "number" },
        "membraneTypeName": { "type": "string" },
        "battenUse": { "type": "boolean" },
        "battenMaterial": { "type": "string" },
        "battenWidthMm": { "type": "number" },
        "battenHeightMm": { "type": "number" },
        "battenStepMm": { "type": "number" },
        "battenLayoutDir": {
          "type": "string",
          "enum": ["perpendicular_to_fall", "parallel_to_fall"]
        },
        "eaveOverhangMm": { "type": "number" },
        "sideOverhangMm": { "type": "number" },
        "soffitReserved": { "type": "boolean" },
        "coveringMaterialName": { "type": "string" },
        "membraneEnabled": { "type": "boolean" },
        "battenEnabled": { "type": "boolean" },
        "battenMaterialName": { "type": "string" },
        "soffitPlanned": { "type": "boolean" }
      }
    },
    "roofAssemblyCalculation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "createdAt", "updatedAt", "roofPlaneIds"],
      "properties": {
        "id": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "roofPlaneIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "wallManufacturingSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "panelNominalWidthMm",
        "minPanelWidthMm",
        "jointBoardThicknessMm",
        "jointBoardDepthMm",
        "plateBoardThicknessMm",
        "plateBoardDepthMm",
        "maxBoardLengthMm",
        "includeEndBoards"
      ],
      "properties": {
        "panelNominalWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "calculationModel": { "type": "string", "enum": ["sip", "frame"] },
        "panelNominalHeightMm": { "type": "number", "exclusiveMinimum": 0 },
        "minPanelWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "jointBoardThicknessMm": { "type": "number", "exclusiveMinimum": 0 },
        "jointBoardDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "plateBoardThicknessMm": { "type": "number", "exclusiveMinimum": 0 },
        "plateBoardDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "maxBoardLengthMm": { "type": "number", "exclusiveMinimum": 0 },
        "includeEndBoards": { "type": "boolean" },
        "coreDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "studSpacingMm": { "type": "number", "exclusiveMinimum": 0 },
        "frameMaterial": { "type": "string", "enum": ["wood", "steel"] },
        "frameMemberWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "framePartitionStudWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "framePartitionStudDepthAlongWallMm": { "type": "number", "exclusiveMinimum": 0 },
        "framePartitionTrackWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "framePartitionTrackDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "doorOpeningFramingPreset": { "type": "string", "enum": ["sip_standard", "frame_gkl_door"] },
        "windowOpeningFramingPreset": {
          "type": "string",
          "enum": ["sip_standard", "frame_gkl_window", "frame_reinforced"]
        }
      }
    },
    "wallCalcSettingsSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "panelNominalWidthMm",
        "minPanelWidthMm",
        "jointBoardThicknessMm",
        "jointBoardDepthMm",
        "plateBoardThicknessMm",
        "plateBoardDepthMm",
        "maxBoardLengthMm",
        "includeEndBoards",
        "wallLengthMm"
      ],
      "properties": {
        "panelNominalWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "calculationModel": { "type": "string", "enum": ["sip", "frame"] },
        "panelNominalHeightMm": { "type": "number", "exclusiveMinimum": 0 },
        "minPanelWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "jointBoardThicknessMm": { "type": "number", "exclusiveMinimum": 0 },
        "jointBoardDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "plateBoardThicknessMm": { "type": "number", "exclusiveMinimum": 0 },
        "plateBoardDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "maxBoardLengthMm": { "type": "number", "exclusiveMinimum": 0 },
        "includeEndBoards": { "type": "boolean" },
        "coreDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "studSpacingMm": { "type": "number", "exclusiveMinimum": 0 },
        "frameMaterial": { "type": "string", "enum": ["wood", "steel"] },
        "frameMemberWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "framePartitionStudWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "framePartitionStudDepthAlongWallMm": { "type": "number", "exclusiveMinimum": 0 },
        "framePartitionTrackWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "framePartitionTrackDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "doorOpeningFramingPreset": { "type": "string", "enum": ["sip_standard", "frame_gkl_door"] },
        "windowOpeningFramingPreset": {
          "type": "string",
          "enum": ["sip_standard", "frame_gkl_window", "frame_reinforced"]
        },
        "wallLengthMm": { "type": "number", "exclusiveMinimum": 0 },
        "profileId": { "type": "string" },
        "stage3OpeningFraming": { "type": "boolean" },
        "stage3WallConnections": { "type": "boolean" }
      }
    },
    "sipPanelRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "wallId",
        "calculationId",
        "index",
        "startOffsetMm",
        "endOffsetMm",
        "widthMm",
        "pieceMark",
        "heightMm",
        "thicknessMm"
      ],
      "properties": {
        "id": { "type": "string" },
        "wallId": { "type": "string" },
        "calculationId": { "type": "string" },
        "index": { "type": "number", "minimum": 0 },
        "startOffsetMm": { "type": "number" },
        "endOffsetMm": { "type": "number" },
        "widthMm": { "type": "number", "exclusiveMinimum": 0 },
        "pieceMark": { "type": "string", "minLength": 1 },
        "heightMm": { "type": "number", "minimum": 0 },
        "thicknessMm": { "type": "number", "minimum": 0 }
      }
    },
    "lumberPiece": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "wallId",
        "calculationId",
        "role",
        "sectionThicknessMm",
        "sectionDepthMm",
        "startOffsetMm",
        "endOffsetMm",
        "lengthMm",
        "orientation"
      ],
      "properties": {
        "id": { "type": "string" },
        "wallId": { "type": "string" },
        "calculationId": { "type": "string" },
        "role": {
          "type": "string",
          "enum": [
            "upper_plate",
            "lower_plate",
            "joint_board",
            "edge_board",
            "opening_left_stud",
            "opening_right_stud",
            "opening_header",
            "opening_cripple",
            "opening_sill",
            "tee_joint_board",
            "corner_joint_board",
            "framing_member_generic",
            "sip_joint_vertical",
            "plate_top",
            "plate_bottom",
            "end_board_vertical"
          ]
        },
        "sectionThicknessMm": { "type": "number", "exclusiveMinimum": 0 },
        "sectionDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "startOffsetMm": { "type": "number" },
        "endOffsetMm": { "type": "number" },
        "lengthMm": { "type": "number", "exclusiveMinimum": 0 },
        "orientation": {
          "type": "string",
          "enum": ["along_wall", "across_wall"]
        },
        "wallMark": { "type": "string" },
        "sequenceNumber": { "type": "number", "minimum": 0 },
        "pieceMark": { "type": "string" },
        "materialType": { "$ref": "#/$defs/profileMaterialType" },
        "sortKey": { "type": "number", "minimum": 0 },
        "displayOrder": { "type": "number", "minimum": 0 },
        "metadata": { "type": "object" }
      }
    },
    "wallCalculationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "wallId",
        "version",
        "generatedAt",
        "settingsSnapshot",
        "sipRegions",
        "lumberPieces"
      ],
      "properties": {
        "id": { "type": "string" },
        "wallId": { "type": "string" },
        "version": { "type": "number", "minimum": 1 },
        "generatedAt": { "type": "string", "minLength": 1 },
        "settingsSnapshot": { "$ref": "#/$defs/wallCalcSettingsSnapshot" },
        "sipRegions": {
          "type": "array",
          "items": { "$ref": "#/$defs/sipPanelRegion" }
        },
        "lumberPieces": {
          "type": "array",
          "items": { "$ref": "#/$defs/lumberPiece" }
        }
      }
    },
    "opening": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "widthMm", "heightMm"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "wallId": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "kind": { "type": "string", "enum": ["door", "window", "other"] },
        "offsetFromStartMm": {
          "anyOf": [{ "type": "number" }, { "type": "null" }]
        },
        "widthMm": { "type": "number", "exclusiveMinimum": 0 },
        "heightMm": { "type": "number", "exclusiveMinimum": 0 },
        "sillHeightMm": { "type": "number", "minimum": 0 },
        "formKey": { "type": "string", "enum": ["rectangle"] },
        "formName": { "type": "string" },
        "isEmptyOpening": { "type": "boolean" },
        "viewPreset": {
          "type": "string",
          "enum": [
            "form1",
            "form2",
            "form3",
            "form4",
            "form5",
            "form6",
            "form7",
            "form8",
            "form9"
          ]
        },
        "sillOverhangMm": { "type": "number", "minimum": 0 },
        "position": {
          "anyOf": [{ "$ref": "#/$defs/openingPositionSpec" }, { "type": "null" }]
        },
        "sipConstruction": {
          "anyOf": [{ "$ref": "#/$defs/openingSipConstructionSpec" }, { "type": "null" }]
        },
        "windowSequenceNumber": { "type": "integer", "minimum": 1 },
        "doorSequenceNumber": { "type": "integer", "minimum": 1 },
        "doorType": { "type": "string", "enum": ["single"] },
        "doorSwing": { "type": "string", "enum": ["in_right", "in_left", "out_right", "out_left"] },
        "doorTrimMm": { "type": "number", "minimum": 0 },
        "markLabel": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "openingPositionSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchorAlongWall", "offsetAlongWallMm", "alignment", "sillLevelMm"],
      "properties": {
        "anchorAlongWall": {
          "type": "string",
          "enum": ["wall_start", "wall_end", "wall_center"]
        },
        "offsetAlongWallMm": { "type": "number" },
        "alignment": {
          "type": "string",
          "enum": ["center", "leading", "trailing"]
        },
        "sillLevelMm": { "type": "number", "minimum": 0 }
      }
    },
    "openingSipConstructionSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aboveProfileId",
        "aboveDouble",
        "lintelTopProfileId",
        "lintelBottomProfileId",
        "sideProfileId",
        "sideType",
        "sideClosingStuds",
        "belowProfileId",
        "belowDouble"
      ],
      "properties": {
        "aboveProfileId": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "aboveDouble": { "type": "boolean" },
        "lintelTopProfileId": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "lintelTopDouble": { "type": "boolean" },
        "lintelBottomProfileId": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "lintelBottomDouble": { "type": "boolean" },
        "sideProfileId": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "sideType": {
          "type": "string",
          "enum": ["type1", "type2", "type3"]
        },
        "sideClosingStuds": { "type": "boolean" },
        "belowProfileId": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "belowDouble": { "type": "boolean" }
      }
