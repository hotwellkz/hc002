{
  "$id": "https://sip-house-designer.local/schema/project-v1.json",
  "title": "SIP House Project v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "name",
    "createdAt",
    "updatedAt",
    "units",
    "layers",
    "activeLayerId",
    "visibleLayerIds",
    "walls",
    "wallCalculations",
    "wallJoints",
    "openings",
    "openingFramingPieces",
    "rooms",
    "foundation",
    "roof",
    "materialSet",
    "sheets",
    "dimensions",
    "settings",
    "viewState",
    "profiles"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "minLength": 1 },
    "updatedAt": { "type": "string", "minLength": 1 },
    "units": { "type": "string", "const": "mm" },
    "activeLayerId": { "type": "string", "minLength": 1 },
    "projectOrigin": {
      "anyOf": [{ "$ref": "#/$defs/point2d" }, { "type": "null" }]
    },
    "visibleLayerIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/layer" }
    },
    "walls": {
      "type": "array",
      "items": { "$ref": "#/$defs/wall" }
    },
    "wallCalculations": {
      "type": "array",
      "items": { "$ref": "#/$defs/wallCalculationResult" }
    },
    "wallJoints": {
      "type": "array",
      "items": { "$ref": "#/$defs/wallJoint" }
    },
    "openings": {
      "type": "array",
      "items": { "$ref": "#/$defs/opening" }
    },
    "openingFramingPieces": {
      "type": "array",
      "items": { "$ref": "#/$defs/openingFramingPiece" }
    },
    "rooms": {
      "type": "array",
      "items": { "$ref": "#/$defs/room" }
    },
    "foundation": { "$ref": "#/$defs/foundation" },
    "roof": { "$ref": "#/$defs/roof" },
    "materialSet": { "$ref": "#/$defs/materialSet" },
    "sheets": {
      "type": "array",
      "items": { "$ref": "#/$defs/sheet" }
    },
    "dimensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/dimension" }
    },
    "settings": { "$ref": "#/$defs/settings" },
    "viewState": { "$ref": "#/$defs/viewState" },
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/profile" }
    }
  },
  "$defs": {
    "point2d": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" }
      }
    },
    "wallJoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "wallAId", "wallAEnd", "wallBId"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["CORNER_BUTT", "CORNER_MITER", "T_ABUTMENT"]
        },
        "wallAId": { "type": "string" },
        "wallAEnd": { "type": "string", "enum": ["start", "end"] },
        "wallBId": { "type": "string" },
        "wallBEnd": { "type": "string", "enum": ["start", "end"] },
        "teePointOnMainMm": { "$ref": "#/$defs/point2d" }
      }
    },
    "layer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "orderIndex", "elevationMm", "isVisible", "createdAt", "updatedAt"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "orderIndex": { "type": "number" },
        "elevationMm": { "type": "number" },
        "isVisible": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "wall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "layerId", "start", "end", "thicknessMm", "heightMm"],
      "properties": {
        "id": { "type": "string" },
        "layerId": { "type": "string" },
        "profileId": { "type": "string" },
        "start": { "$ref": "#/$defs/point2d" },
        "end": { "$ref": "#/$defs/point2d" },
        "thicknessMm": { "type": "number", "minimum": 0 },
        "heightMm": { "type": "number", "minimum": 0 },
        "baseElevationMm": { "type": "number" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "placementGroupId": { "type": "string" },
        "markPrefix": { "type": "string" },
        "markSequenceNumber": { "type": "number" },
        "markLabel": { "type": "string" }
      }
    },
    "profileMaterialType": {
      "type": "string",
      "enum": ["osb", "eps", "xps", "wood", "steel", "gypsum", "concrete", "membrane", "insulation", "custom"]
    },
    "profileCategory": {
      "type": "string",
      "enum": ["wall", "slab", "roof", "beam", "pipe", "board", "custom"]
    },
    "profileCompositionMode": {
      "type": "string",
      "enum": ["layered", "solid"]
    },
    "profileLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "orderIndex", "materialName", "materialType", "thicknessMm"],
      "properties": {
        "id": { "type": "string" },
        "orderIndex": { "type": "number" },
        "materialName": { "type": "string" },
        "materialType": { "$ref": "#/$defs/profileMaterialType" },
        "thicknessMm": { "type": "number", "exclusiveMinimum": 0 },
        "widthMm": { "type": "number" },
        "heightMm": { "type": "number" },
        "note": { "type": "string" }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "category",
        "compositionMode",
        "layers",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "$ref": "#/$defs/profileCategory" },
        "compositionMode": { "$ref": "#/$defs/profileCompositionMode" },
        "defaultHeightMm": { "type": "number" },
        "defaultWidthMm": { "type": "number" },
        "defaultThicknessMm": { "type": "number" },
        "notes": { "type": "string" },
        "markPrefix": { "type": "string" },
        "wallManufacturing": { "$ref": "#/$defs/wallManufacturingSettings" },
        "layers": {
          "type": "array",
          "items": { "$ref": "#/$defs/profileLayer" }
        },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "wallManufacturingSettings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "panelNominalWidthMm",
        "minPanelWidthMm",
        "jointBoardThicknessMm",
        "jointBoardDepthMm",
        "plateBoardThicknessMm",
        "plateBoardDepthMm",
        "maxBoardLengthMm",
        "includeEndBoards"
      ],
      "properties": {
        "panelNominalWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "panelNominalHeightMm": { "type": "number", "exclusiveMinimum": 0 },
        "minPanelWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "jointBoardThicknessMm": { "type": "number", "exclusiveMinimum": 0 },
        "jointBoardDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "plateBoardThicknessMm": { "type": "number", "exclusiveMinimum": 0 },
        "plateBoardDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "maxBoardLengthMm": { "type": "number", "exclusiveMinimum": 0 },
        "includeEndBoards": { "type": "boolean" },
        "coreDepthMm": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "wallCalcSettingsSnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "panelNominalWidthMm",
        "minPanelWidthMm",
        "jointBoardThicknessMm",
        "jointBoardDepthMm",
        "plateBoardThicknessMm",
        "plateBoardDepthMm",
        "maxBoardLengthMm",
        "includeEndBoards",
        "wallLengthMm"
      ],
      "properties": {
        "panelNominalWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "panelNominalHeightMm": { "type": "number", "exclusiveMinimum": 0 },
        "minPanelWidthMm": { "type": "number", "exclusiveMinimum": 0 },
        "jointBoardThicknessMm": { "type": "number", "exclusiveMinimum": 0 },
        "jointBoardDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "plateBoardThicknessMm": { "type": "number", "exclusiveMinimum": 0 },
        "plateBoardDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "maxBoardLengthMm": { "type": "number", "exclusiveMinimum": 0 },
        "includeEndBoards": { "type": "boolean" },
        "coreDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "wallLengthMm": { "type": "number", "exclusiveMinimum": 0 },
        "profileId": { "type": "string" },
        "stage3OpeningFraming": { "type": "boolean" },
        "stage3WallConnections": { "type": "boolean" }
      }
    },
    "sipPanelRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "wallId",
        "calculationId",
        "index",
        "startOffsetMm",
        "endOffsetMm",
        "widthMm",
        "pieceMark",
        "heightMm",
        "thicknessMm"
      ],
      "properties": {
        "id": { "type": "string" },
        "wallId": { "type": "string" },
        "calculationId": { "type": "string" },
        "index": { "type": "number", "minimum": 0 },
        "startOffsetMm": { "type": "number" },
        "endOffsetMm": { "type": "number" },
        "widthMm": { "type": "number", "exclusiveMinimum": 0 },
        "pieceMark": { "type": "string", "minLength": 1 },
        "heightMm": { "type": "number", "minimum": 0 },
        "thicknessMm": { "type": "number", "minimum": 0 }
      }
    },
    "lumberPiece": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "wallId",
        "calculationId",
        "role",
        "sectionThicknessMm",
        "sectionDepthMm",
        "startOffsetMm",
        "endOffsetMm",
        "lengthMm",
        "orientation"
      ],
      "properties": {
        "id": { "type": "string" },
        "wallId": { "type": "string" },
        "calculationId": { "type": "string" },
        "role": {
          "type": "string",
          "enum": [
            "upper_plate",
            "lower_plate",
            "joint_board",
            "edge_board",
            "opening_left_stud",
            "opening_right_stud",
            "opening_header",
            "opening_sill",
            "tee_joint_board",
            "corner_joint_board",
            "framing_member_generic",
            "sip_joint_vertical",
            "plate_top",
            "plate_bottom",
            "end_board_vertical"
          ]
        },
        "sectionThicknessMm": { "type": "number", "exclusiveMinimum": 0 },
        "sectionDepthMm": { "type": "number", "exclusiveMinimum": 0 },
        "startOffsetMm": { "type": "number" },
        "endOffsetMm": { "type": "number" },
        "lengthMm": { "type": "number", "exclusiveMinimum": 0 },
        "orientation": {
          "type": "string",
          "enum": ["along_wall", "across_wall"]
        },
        "wallMark": { "type": "string" },
        "sequenceNumber": { "type": "number", "minimum": 0 },
        "pieceMark": { "type": "string" },
        "materialType": { "$ref": "#/$defs/profileMaterialType" },
        "sortKey": { "type": "number", "minimum": 0 },
        "displayOrder": { "type": "number", "minimum": 0 },
        "metadata": { "type": "object" }
      }
    },
    "wallCalculationResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "wallId",
        "version",
        "generatedAt",
        "settingsSnapshot",
        "sipRegions",
        "lumberPieces"
      ],
      "properties": {
        "id": { "type": "string" },
        "wallId": { "type": "string" },
        "version": { "type": "number", "minimum": 1 },
        "generatedAt": { "type": "string", "minLength": 1 },
        "settingsSnapshot": { "$ref": "#/$defs/wallCalcSettingsSnapshot" },
        "sipRegions": {
          "type": "array",
          "items": { "$ref": "#/$defs/sipPanelRegion" }
        },
        "lumberPieces": {
          "type": "array",
          "items": { "$ref": "#/$defs/lumberPiece" }
        }
      }
    },
    "opening": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "widthMm", "heightMm"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "wallId": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "kind": { "type": "string", "enum": ["door", "window", "other"] },
        "offsetFromStartMm": {
          "anyOf": [{ "type": "number" }, { "type": "null" }]
        },
        "widthMm": { "type": "number", "exclusiveMinimum": 0 },
        "heightMm": { "type": "number", "exclusiveMinimum": 0 },
        "sillHeightMm": { "type": "number", "minimum": 0 },
        "formKey": { "type": "string", "enum": ["rectangle"] },
        "formName": { "type": "string" },
        "isEmptyOpening": { "type": "boolean" },
        "viewPreset": {
          "type": "string",
          "enum": [
            "form1",
            "form2",
            "form3",
            "form4",
            "form5",
            "form6",
            "form7",
            "form8",
            "form9"
          ]
        },
        "sillOverhangMm": { "type": "number", "minimum": 0 },
        "position": {
          "anyOf": [{ "$ref": "#/$defs/openingPositionSpec" }, { "type": "null" }]
        },
        "sipConstruction": {
          "anyOf": [{ "$ref": "#/$defs/openingSipConstructionSpec" }, { "type": "null" }]
        },
        "windowSequenceNumber": { "type": "integer", "minimum": 1 },
        "doorSequenceNumber": { "type": "integer", "minimum": 1 },
        "doorType": { "type": "string", "enum": ["single"] },
        "doorSwing": { "type": "string", "enum": ["in_right", "in_left", "out_right", "out_left"] },
        "doorTrimMm": { "type": "number", "minimum": 0 },
        "markLabel": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      }
    },
    "openingPositionSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["anchorAlongWall", "offsetAlongWallMm", "alignment", "sillLevelMm"],
      "properties": {
        "anchorAlongWall": {
          "type": "string",
          "enum": ["wall_start", "wall_end", "wall_center"]
        },
        "offsetAlongWallMm": { "type": "number" },
        "alignment": {
          "type": "string",
          "enum": ["center", "leading", "trailing"]
        },
        "sillLevelMm": { "type": "number", "minimum": 0 }
      }
    },
    "openingSipConstructionSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aboveProfileId",
        "aboveDouble",
        "lintelTopProfileId",
        "lintelBottomProfileId",
        "sideProfileId",
        "sideType",
        "sideClosingStuds",
        "belowProfileId",
        "belowDouble"
      ],
      "properties": {
        "aboveProfileId": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "aboveDouble": { "type": "boolean" },
        "lintelTopProfileId": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "lintelTopDouble": { "type": "boolean" },
        "lintelBottomProfileId": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "lintelBottomDouble": { "type": "boolean" },
        "sideProfileId": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "sideType": {
          "type": "string",
          "enum": ["type1", "type2", "type3"]
        },
        "sideClosingStuds": { "type": "boolean" },
        "belowProfileId": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        },
        "belowDouble": { "type": "boolean" }
      }
    },
    "openingFramingPiece": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "openingId", "wallId", "kind", "profileId", "lengthMm", "markLabel", "sequenceIndex"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "openingId": { "type": "string", "minLength": 1 },
        "wallId": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "above",
            "lintel_top",
            "lintel_bottom",
            "side_left",
            "side_right",
            "side_fix_left",
            "side_fix_right",
            "below"
          ]
        },
        "profileId": { "type": "string", "minLength": 1 },
        "lengthMm": { "type": "number", "exclusiveMinimum": 0 },
        "markLabel": { "type": "string" },
        "sequenceIndex": { "type": "number" }
      }
    },
    "room": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "layerId", "name"],
      "properties": {
        "id": { "type": "string" },
        "layerId": { "type": "string" },
        "name": { "type": "string" },
        "polygonMm": {
          "type": "array",
          "items": { "$ref": "#/$defs/point2d" }
        }
      }
    },
    "foundation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["none", "strip", "slab", "other"] },
        "notes": { "type": "string" }
      }
    },
    "roofSlope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "azimuthDeg": { "type": "number" },
        "pitchDeg": { "type": "number" }
      }
    },
    "roof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slopes"],
      "properties": {
        "slopes": {
          "type": "array",
          "items": { "$ref": "#/$defs/roofSlope" }
        },
        "notes": { "type": "string" }
      }
    },
    "materialSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "panelThicknessMm": { "type": "number", "minimum": 0 }
      }
    },
    "sheet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "widthMm", "heightMm"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "widthMm": { "type": "number", "minimum": 0 },
        "heightMm": { "type": "number", "minimum": 0 }
      }
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "a", "b"],
      "properties": {
        "id": { "type": "string" },
        "a": { "$ref": "#/$defs/point2d" },
        "b": { "$ref": "#/$defs/point2d" },
        "offsetMm": { "type": "number" },
        "kind": {
          "type": "string",
          "enum": ["rectangle_outer_horizontal", "rectangle_outer_vertical"]
        },
        "placementGroupId": { "type": "string" },
        "wallIds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "layerId": { "type": "string" },
        "textValueMm": { "type": "number" },
        "extensionOvershootMm": { "type": "number" }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gridStepMm", "showGrid", "editor2d"],
      "properties": {
        "gridStepMm": { "type": "number", "exclusiveMinimum": 0 },
        "showGrid": { "type": "boolean" },
        "editor2d": {
          "type": "object",
          "additionalProperties": false,
          "required": ["linearPlacementMode", "wallShapeMode"],
          "properties": {
            "linearPlacementMode": {
              "type": "string",
              "enum": ["center", "leftEdge", "rightEdge"]
            },
            "wallShapeMode": {
              "type": "string",
              "enum": ["line", "rectangle"]
            },
            "snapToVertex": { "type": "boolean" },
            "snapToEdge": { "type": "boolean" },
            "snapToGrid": { "type": "boolean" },
            "debugLumberPieceLabels2d": { "type": "boolean" }
          }
        }
      }
    },
    "viewState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["activeTab", "viewport2d", "viewport3d"],
      "properties": {
        "rightPropertiesCollapsed": { "type": "boolean" },
        "show3dProfileLayers": { "type": "boolean" },
        "show2dProfileLayers": { "type": "boolean" },
        "show3dCalculation": { "type": "boolean" },
        "show3dLayerOsb": { "type": "boolean" },
        "show3dLayerEps": { "type": "boolean" },
        "show3dLayerFrame": { "type": "boolean" },
        "show3dLayerWindows": { "type": "boolean" },
        "show3dLayerDoors": { "type": "boolean" },
        "activeTab": { "type": "string", "enum": ["2d", "3d", "spec", "wall"] },
        "viewport2d": {
          "type": "object",
          "additionalProperties": false,
          "required": ["panXMm", "panYMm", "zoomPixelsPerMm"],
          "properties": {
            "panXMm": { "type": "number" },
            "panYMm": { "type": "number" },
            "zoomPixelsPerMm": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        "viewport3d": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "polarAngle",
            "azimuthalAngle",
            "distance",
            "targetXMm",
            "targetYMm",
            "targetZMm"
          ],
          "properties": {
            "polarAngle": { "type": "number" },
            "azimuthalAngle": { "type": "number" },
            "distance": { "type": "number", "exclusiveMinimum": 0 },
            "targetXMm": { "type": "number" },
            "targetYMm": { "type": "number" },
            "targetZMm": { "type": "number" }
          }
        }
      }
    }
  }
}
