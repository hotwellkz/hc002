        "rightPropertiesCollapsed": { "type": "boolean" },
        "show3dProfileLayers": { "type": "boolean" },
        "show2dProfileLayers": { "type": "boolean" },
        "show3dCalculation": { "type": "boolean" },
        "show3dLayerOsb": { "type": "boolean" },
        "show3dLayerEps": { "type": "boolean" },
        "show3dLayerFrame": { "type": "boolean" },
        "show3dLayerGypsum": { "type": "boolean" },
        "show3dLayerWindows": { "type": "boolean" },
        "show3dLayerDoors": { "type": "boolean" },
        "show3dGrid": { "type": "boolean" },
        "show3dFoundation": { "type": "boolean" },
        "show3dPiles": { "type": "boolean" },
        "show3dOverlap": { "type": "boolean" },
        "show3dRoof": { "type": "boolean" },
        "show3dRoofMembrane": { "type": "boolean" },
        "show3dRoofBattens": { "type": "boolean" },
        "show3dRoofCovering": { "type": "boolean" },
        "show3dRoofSoffit": { "type": "boolean" },
        "activeTab": { "type": "string", "enum": ["2d", "3d", "spec", "wall"] },
        "editor2dPlanScope": {
          "type": "string",
          "enum": ["main", "floorStructure", "foundation", "roof"]
        },
        "viewport2d": {
          "type": "object",
          "additionalProperties": false,
          "required": ["panXMm", "panYMm", "zoomPixelsPerMm"],
          "properties": {
            "panXMm": { "type": "number" },
            "panYMm": { "type": "number" },
            "zoomPixelsPerMm": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        "viewport3d": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "polarAngle",
            "azimuthalAngle",
            "distance",
            "targetXMm",
            "targetYMm",
            "targetZMm"
          ],
          "properties": {
            "polarAngle": { "type": "number" },
            "azimuthalAngle": { "type": "number" },
            "distance": { "type": "number", "exclusiveMinimum": 0 },
            "targetXMm": { "type": "number" },
            "targetYMm": { "type": "number" },
            "targetZMm": { "type": "number" }
          }
        }
      }
